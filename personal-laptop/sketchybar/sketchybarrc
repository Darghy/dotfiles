#!/usr/bin/env bash
# Basic SketchyBar config with AeroSpace workspace integration

PLUGIN_DIR="$CONFIG_DIR/plugins"
AEROSPACE=/opt/homebrew/bin/aerospace

# --- Bar appearance ---
sketchybar --bar \
  position=top \
  height=38 \
  blur_radius=30 \
  color=0xcc1e1e2e

# --- Defaults for all items ---
sketchybar --default \
  padding_left=4 \
  padding_right=4 \
  icon.font="SF Pro Text:Semibold:14.0" \
  icon.color=0xffcdd6f4 \
  label.font="SF Pro Text:Semibold:13.0" \
  label.color=0xffcdd6f4 \
  label.padding_left=6 \
  label.padding_right=6

# --- AeroSpace workspaces (left): number + app icons ---
sketchybar --add event aerospace_workspace_change

for sid in $($AEROSPACE list-workspaces --all); do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      icon="$sid" \
      icon.padding_left=8 \
      icon.padding_right=2 \
      label.font="sketchybar-app-font:Regular:15.0" \
      label.padding_left=2 \
      label.padding_right=8 \
      label.y_offset=-1 \
      label.drawing=off \
      background.color=0x66494d64 \
      background.corner_radius=6 \
      background.height=26 \
      background.drawing=off \
      click_script="$AEROSPACE workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

# Invisible helper: refreshes the app icons in the workspace items
sketchybar --add item space_icons left \
  --subscribe space_icons aerospace_workspace_change front_app_switched \
  --set space_icons drawing=off update_freq=10 script="$PLUGIN_DIR/space_icons.sh"

# --- Focused app name (after workspaces) ---
sketchybar --add item front_app left \
  --subscribe front_app front_app_switched \
  --set front_app \
    label.font="SF Pro Text:Bold:13.0" \
    padding_left=12 \
    label.padding_left=8 \
    label.padding_right=8 \
    background.color=0x66494d64 \
    background.corner_radius=6 \
    background.height=26 \
    background.drawing=on \
    script="$PLUGIN_DIR/front_app.sh"

# --- Right side: clock, battery, wifi, cpu (first added = rightmost) ---
# Pill style matching the workspace items
PILL=(
  background.color=0x66494d64
  background.corner_radius=6
  background.height=26
  background.drawing=on
  icon.padding_left=8
  label.padding_right=8
)

sketchybar --add item clock right \
  --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh" "${PILL[@]}" \
    icon.drawing=off \
    icon.padding_left=0 \
    icon.padding_right=0 \
    label.padding_left=8

sketchybar --add item battery right \
  --subscribe battery system_woke power_source_change \
  --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" "${PILL[@]}"

sketchybar --add item wifi right \
  --subscribe wifi wifi_change system_woke \
  --set wifi update_freq=30 script="$PLUGIN_DIR/wifi.sh" "${PILL[@]}" \
    icon.padding_right=8 \
    label.drawing=off \
    label.padding_left=0 \
    label.padding_right=0

sketchybar --add item cpu right \
  --set cpu update_freq=5 script="$PLUGIN_DIR/cpu.sh" "${PILL[@]}"

# --- Initialize ---
sketchybar --update
"$PLUGIN_DIR/space_icons.sh"
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$($AEROSPACE list-workspaces --focused)"
